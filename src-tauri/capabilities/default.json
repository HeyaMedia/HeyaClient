{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "native-bridge:allow-native-audio-request",
    "native-bridge:allow-native-playback-request",
    "native-bridge:allow-system-media-request",
    "native-bridge:allow-native-window-request",
    "native-bridge:allow-application-request"
  ]
}
