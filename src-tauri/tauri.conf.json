{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Heya",
  "version": "0.1.0",
  "identifier": "media.heya.client",
  "build": {
    "beforeDevCommand": "bun run bootstrap:build",
    "beforeBuildCommand": "bun run bootstrap:build",
    "frontendDist": "../bootstrap/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Heya",
        "width": 800,
        "height": 600,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "create": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
