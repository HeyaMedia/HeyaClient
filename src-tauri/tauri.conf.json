{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Heya",
  "version": "0.2.22",
  "identifier": "media.heya.client",
  "build": {
    "beforeDevCommand": "bun run bootstrap:build",
    "beforeBuildCommand": "bun run bootstrap:build",
    "frontendDist": "../bootstrap/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Heya",
        "width": 800,
        "height": 600,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "create": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5MjZFRjkxNUI1QjIyOUEKUldTYUlsdGJrZThtMmJ4c2R2K0dEblVNVXZPbFBhc3liVUpld2x0MXhUeW1CWnBrSFR0UmR2b0QK",
      "endpoints": [
        "https://github.com/HeyaMedia/HeyaClient/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
